{
  "fitting": {
    "tool": "lmfit",
    "histogram_config": {
      "target_variable": "zmass",
      "x_min_gev": 75,
      "x_max_gev": 105,
      "bin_width_gev": 1.5
    },
    "model_components": {
      "signal": {
        "type": "breit_wigner",
        "description": "Z boson mass peak fit from SFOS lepton pair",
        "initial_guesses": {
          "amplitude": "max_bin_count",
          "center": 91.2,
          "sigma": 2.5
        },
        "bounds": {
          "amplitude": [0, "inf"],
          "center": [85, 95],
          "sigma": [1.0, 5.0]
        }
      },
      "background": {
        "type": "polynomial",
        "order": 1,
        "initial_guesses": {
          "c0": "mean_bin_count",
          "c1": 0
        }
      }
    },
    "fit_configuration": {
      "combined_model": "signal + background",
      "weights_formula": "1 / sqrt(data_x)"
    }
  },
  "plotting": {
    "layout": {
      "type": "stacked_panels",
      "top_panel_fraction": 0.75,
      "bottom_panel_fraction": 0.25,
      "x_range_gev": [75, 105],
      "bin_width_gev": 1.5
    },
    "main_panel": {
      "x_axis_label": "M_{\\ell\\ell} [GeV]",
      "y_axis_label": "events / bin",
      "y_axis_scale": "linear",
      "minor_ticks": true,
      "traces": [
        {
          "name": "Data",
          "data_source": "observed_histogram",
          "type": "scatter_error_bars",
          "style": "black_circles"
        },
        {
          "name": "Backgrounds and Signal",
          "data_source": "MC_samples",
          "type": "stacked_histogram",
          "components": [
            {"name": "V+jets", "color": "green"},
            {"name": "OTHER", "color": "orange"},
            {"name": "ZZ,WW", "color": "slateblue"},
            {"name": "WZ (Signal)", "color": "lightcoral"}
          ]
        },
        {
          "name": "Z Peak Fit",
          "data_source": "combined_model_fit",
          "type": "line",
          "style": "dashed_red"
        }
      ],
      "text_annotations": [
        "ATLAS Open Data",
        "for education",
        "\\sqrt{s}=13 TeV, 36.6 fb^{-1}",
        "WZ \\rightarrow \\ell\\ell\\ell\\nu"
      ]
    },
    "residual_panel": {
      "x_axis_label": "M_{\\ell\\ell} [GeV]",
      "y_axis_label": "Ratio (Data/MC)",
      "y_axis_range": [0.5, 1.5],
      "minor_ticks": true,
      "traces": [
        {
          "name": "Ratio",
          "data_source": "Data / MC_Total",
          "type": "scatter_error_bars",
          "style": "black_circles"
        },
        {
          "name": "Unity Reference",
          "data_source": "1.0",
          "type": "line",
          "style": "dashed_red"
        }
      ]
    }
  }
}
